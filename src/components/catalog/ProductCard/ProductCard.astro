---
import './ProductCard.css';
import heartSvg   from '@/assets/icons/heart.svg?raw';
import compareSvg from '@/assets/icons/compare.svg?raw';
import starSvg    from '@/assets/icons/star.svg?raw';

interface Props {
  id?: number;
  image: string;
  title: string;
  href: string;
  price: number;
  oldPrice?: number;
  rating?: number;
  status?: 'instock' | 'outofstock';
  article?: string;
  badge?: string;
}

const {
  id, image, title, href, price,
  oldPrice, rating, status = 'instock',
  article, badge,
} = Astro.props;
---

<article class="pc">

  <a href={href} class="pc-img-l">
    <img class="pc-img" src={image} alt={title} loading="lazy" width="240" height="240" />
    {badge && <span class="pc-bdg">{badge}</span>}
  </a>

  <div class="pc-info">
    <div class="pc-pr">
      <span class="pc-pr-n">{price} ₽</span>
      {oldPrice && <span class="pc-pr-o">{oldPrice} ₽</span>}
    </div>

    <a href={href} class="pc-ttl">{title}</a>

    <div class="pc-meta">
      {rating && (
        <span class="pc-rt">
          <Fragment set:html={starSvg} />
          {rating}
        </span>
      )}
      <span class={`pc-sta ${status}`}>
        {status === 'instock' ? 'Есть в наличии' : 'Нет в наличии'}
      </span>
      {article && <span class="pc-art">Арт. {article}</span>}
    </div>
  </div>

  <div class="pc-foot">
    <button
      class="pc-btn"
      type="button"
      data-product-id={id != null ? String(id) : undefined}
      data-product-title={title}
      data-product-image={image}
      data-product-price={String(price)}
      data-product-href={href}
    >В корзину</button>
    <div class="pc-act">
      <button
        class="pc-fav-btn"
        type="button"
        aria-label="В избранное"
        data-product-id={id != null ? String(id) : undefined}
        data-product-title={title}
        data-product-image={image}
        data-product-price={String(price)}
        data-product-href={href}
        data-product-oldprice={oldPrice != null ? String(oldPrice) : undefined}
        data-product-rating={rating != null ? String(rating) : undefined}
        data-product-status={status}
        data-product-article={article}
        data-product-badge={badge}
      >
        <Fragment set:html={heartSvg} />
      </button>
      <button
        class="pc-cmp-btn"
        type="button"
        aria-label="Сравнить"
        data-product-id={id != null ? String(id) : undefined}
        data-product-title={title}
        data-product-image={image}
        data-product-price={String(price)}
        data-product-href={href}
        data-product-oldprice={oldPrice != null ? String(oldPrice) : undefined}
        data-product-rating={rating != null ? String(rating) : undefined}
        data-product-status={status}
        data-product-article={article}
        data-product-badge={badge}
      >
        <Fragment set:html={compareSvg} />
      </button>
    </div>
  </div>

</article>
