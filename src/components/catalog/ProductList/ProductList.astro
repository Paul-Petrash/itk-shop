---
import './ProductList.css';
import ProductCard from '@/components/catalog/ProductCard/ProductCard.astro';

interface Product {
  id: number;
  image: string;
  title: string;
  href: string;
  price: number;
  oldPrice?: number;
  rating?: number;
  status?: 'instock' | 'outofstock';
  article?: string;
  badge?: string;
}

interface Props {
  title: string;
  titleHref?: string;
  products: Product[];
}

const { title, titleHref = '#', products } = Astro.props;
---

<section class="pl">
  <div class="wrap">

    <div class="pl-hd">
      <h2 class="pl-ttl">
        <a href={titleHref}>{title}</a>
        <svg width="7" height="12" viewBox="0 0 7 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M1 1l5 5-5 5"/>
        </svg>
      </h2>
    </div>

    <div class="pl-grid">
      {products.map(p => <ProductCard {...p} />)}
    </div>

  </div>
</section>
