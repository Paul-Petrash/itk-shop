---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/ui/Header/Header.astro';
import Footer from '@/components/ui/Footer/Footer.astro';
import CategoryCard from '@/components/catalog/CategoryCard/CategoryCard.astro';
import { getCategories } from '@/lib/api';
import './catalog.css';

const categories = await getCategories();
---

<Layout
  title="Каталог товаров — ITK SHOP"
  description="Полный каталог: вода, кулеры, фильтры, помпы и расходники. Быстрая доставка."
>
  <Header />
  <main class="wrap">

    <nav class="breadcrumb">
      <a href="/">Главная</a>
      <span>/</span>
      <span>Каталог</span>
    </nav>

    <h1 class="catalog-title">Каталог товаров</h1>

    <div class="cat-grid">
      {categories.map(c => (
        <CategoryCard
          title={c.title}
          image={c.image}
          href={`/catalog/${c.slug}/`}
          productCount={c.productCount}
        />
      ))}
    </div>

  </main>
  <Footer />
</Layout>
