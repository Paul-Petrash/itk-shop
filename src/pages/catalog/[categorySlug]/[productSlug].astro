---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/ui/Header/Header.astro';
import Footer from '@/components/ui/Footer/Footer.astro';
import { getCategories, getProductsByCategory, getProduct } from '@/lib/api';
import type { Product, Category } from '@/lib/types';

export async function getStaticPaths() {
  const categories = await getCategories();
  const paths = await Promise.all(
    categories.map(async (cat) => {
      const products = await getProductsByCategory(cat.slug);
      return products.map(p => ({
        params: { categorySlug: cat.slug, productSlug: p.slug },
        props: { product: p, category: cat },
      }));
    })
  );
  return paths.flat();
}

interface Props {
  product: Product;
  category: Category;
}

const { product, category } = Astro.props;
---

<Layout
  title={`${product.title} — ITK SHOP`}
  description={product.description ?? `Купить ${product.title} по цене ${product.price} ₽. Доставка по всей России.`}
>
  <Header />
  <main class="wrap">

    <nav class="breadcrumb" itemscope itemtype="http://schema.org/BreadcrumbList">
      <span itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
        <a itemprop="item" href="/"><span itemprop="name">Главная</span></a>
        <meta itemprop="position" content="1" />
      </span>
      <span>/</span>
      <span itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
        <a itemprop="item" href="/catalog/"><span itemprop="name">Каталог</span></a>
        <meta itemprop="position" content="2" />
      </span>
      <span>/</span>
      <span itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
        <a itemprop="item" href={`/catalog/${category.slug}/`}><span itemprop="name">{category.title}</span></a>
        <meta itemprop="position" content="3" />
      </span>
      <span>/</span>
      <span itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
        <span itemprop="name">{product.title}</span>
        <meta itemprop="position" content="4" />
      </span>
    </nav>

    <article class="product" itemscope itemtype="http://schema.org/Product">
      <meta itemprop="name" content={product.title} />
      {product.article && <meta itemprop="sku" content={product.article} />}

      <div class="product-gallery">
        <img
          src={product.image}
          alt={product.title}
          width="480"
          height="480"
          loading="eager"
          itemprop="image"
        />
      </div>

      <div class="product-info">
        {product.badge && <span class="product-badge">{product.badge}</span>}
        <h1 class="product-title" itemprop="name">{product.title}</h1>
        {product.article && <p class="product-article">Арт. {product.article}</p>}

        <div itemprop="offers" itemscope itemtype="http://schema.org/Offer">
          <link itemprop="availability" href={product.status === 'outofstock'
            ? 'http://schema.org/OutOfStock'
            : 'http://schema.org/InStock'} />
          <meta itemprop="priceCurrency" content="RUB" />
          <meta itemprop="price" content={String(product.price)} />

          <div class="product-price">
            <span class="product-price-current">{product.price} ₽</span>
            {product.oldPrice && (
              <span class="product-price-old">{product.oldPrice} ₽</span>
            )}
          </div>

          <p class={`product-stock ${product.status ?? 'instock'}`}>
            {(product.status ?? 'instock') === 'instock' ? 'Есть в наличии' : 'Нет в наличии'}
          </p>
        </div>

        {product.description && (
          <p class="product-description" itemprop="description">{product.description}</p>
        )}

        <button class="btn-primary" type="button">В корзину</button>
      </div>
    </article>

  </main>
  <Footer />
</Layout>

<style>
  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    padding: 1rem 0;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .breadcrumb a { color: inherit; text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }

  .product {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    padding: 1rem 0 3rem;
  }

  @media (max-width: 768px) {
    .product { grid-template-columns: 1fr; }
  }

  .product-gallery img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    object-fit: contain;
    border: 1px solid var(--color-border);
  }

  .product-badge {
    display: inline-block;
    background: #f91155;
    color: #fff;
    padding: 3px 10px;
    border-radius: var(--radius-sm);
    font-size: var(--text-xs);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .product-title {
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.375rem;
  }

  .product-article {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .product-price {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin: 0.75rem 0 0.375rem;
  }

  .product-price-current { font-size: 2rem; font-weight: 700; }

  .product-price-old {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    text-decoration: line-through;
  }

  .product-stock {
    font-size: var(--text-sm);
    margin-bottom: 1rem;
    color: var(--color-text-muted);
  }

  .product-stock.instock  { color: #3cb371; }
  .product-stock.outofstock { color: #c0392b; }

  .product-description {
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    font-size: var(--text-md);
  }

  .btn-primary {
    background: var(--color-theme);
    color: #fff;
    border: none;
    border-radius: var(--radius-md);
    padding: 0.875rem 2rem;
    font-size: var(--text-lg);
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: background .2s;
  }

  .btn-primary:hover { background: var(--color-theme-hover); }
</style>