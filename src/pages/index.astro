---
import Layout from '@/layouts/Layout.astro';
import Header from '@/components/ui/Header/Header.astro';
import Footer from '@/components/ui/Footer/Footer.astro';
import ProductList from '@/components/catalog/ProductList/ProductList.astro';
import { getProducts } from '@/lib/api';

const allProducts = await getProducts();
const featured = allProducts
  .slice(0, 5)
  .map(p => ({ ...p, href: `/catalog/${p.categorySlug}/${p.slug}/` }));
---

<Layout
  title="ITK SHOP — вода и оборудование"
  description="Интернет-магазин воды и оборудования для водоснабжения. Кулеры, фильтры, помпы с доставкой."
>
  <Header />
  <main>
    <ProductList title="Лучшие предложения" titleHref="/catalog/" products={featured} />
  </main>
  <Footer />
</Layout>